{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Twillo Clinic Console",
  "version": "0.1.2",
  "identifier": "com.twillo-callbot.desktop",
  "build": {
    "beforeDevCommand": "node scripts/start-front-if-needed.mjs",
    "devUrl": "http://localhost:3200/softphone",
    "beforeBuildCommand": "npm --prefix ../twillo-callbot-front run build",
    "frontendDist": "../../twillo-callbot-front/out"
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE5NzEzQjAzMUZFRjIzRDEKUldUUkkrOGZBenR4cVM4eDZqZ2dKNmYwajVabUo4M3BjTXFTSS85eS9FaVc2WFFlQzM2Q1FWRTIK",
      "endpoints": [
        "https://github.com/dota-pilot1/twillo-callbot-tauri/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Twillo Clinic Console",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
